# === Optional (with defaults) ===
MAX_PARALLEL_RUNNERS=3
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=300
BASE_BRANCH=main
REPO_PATH=/workspace
WORKSPACE_PATH=./workspace   # host path to target git repo, mounted at /workspace

# Repo context size limits (applied by collectRepoContext / renderContextForPrompt)
REPO_CONTEXT_MAX_FILE_CHARS=8000    # per-file character cap; content beyond this is dropped with a truncation marker
REPO_CONTEXT_MAX_TOTAL_CHARS=32000  # cap on the combined rendered context string sent to the refine model
