# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...

# === Database ===
# Dev: DATABASE_URL="file:./dev.sqlite"
# Docker: DATABASE_URL="file:/data/db.sqlite"
DATABASE_URL="file:./dev.sqlite"

# === Optional (with defaults) ===
MAX_PARALLEL_RUNNERS=3
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=300
BASE_BRANCH=main
REPO_PATH=/workspace
