# === Optional (with defaults) ===
MAX_PARALLEL_RUNNERS=3
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=300
BASE_BRANCH=main
REPO_PATH=/workspace
WORKSPACE_PATH=./workspace   # host path to target git repo, mounted at /workspace

# Auto-resolve / auto-merge knobs (only used for tasks with `requiresHumanReview = false`)
NIGHTCODER_AUTO_RESOLVE_MAX_ATTEMPTS=3
NIGHTCODER_AUTO_MERGE_POLL_MS=15000
