{
  "name": "nightcoder",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c magenta,cyan \"pnpm --filter desktop dev:renderer\" \"wait-on http://localhost:5173 && pnpm --filter desktop dev:main\"",
    "build": "pnpm --filter desktop build",
    "dist:mac": "pnpm --filter desktop dist:mac",
    "lint": "eslint \"{apps,libs}/**/*.{ts,tsx}\"",
    "typecheck": "pnpm --filter desktop typecheck && tsc -p libs/design-system/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:install": "playwright install chromium",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.2",
    "storybook": "^10.3.5",
    "tailwindcss": "4.2.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.90.0",
    "@prisma/client": "6.19.3",
    "execa": "^9.6.1",
    "prisma": "6.19.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "zod": "^4.3.6"
  }
}
